# Core runtime
NODE_ENV=development
PORT=5180
SESSION_SECRET=change-this-to-a-long-random-secret
BASE_HOST=localhost

# Required database connection (local PostgreSQL)
# Create user/database first, then use this URL format.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/wytnet_local

# Optional integrations (keep empty for local MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
MEILISEARCH_URL=http://127.0.0.1:7700
MEILISEARCH_API_KEY=
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=
